#pragma once

/** @file libcwd/config.h
 * Do not include this header file directly, instead include "@ref preparation_step2 "debug.h"".
 */

#ifndef LIBCWD_CONFIG_H
#define LIBCWD_CONFIG_H

//
// clang-format off
//
// DO NOT CHANGE THIS FILE
//
// The defines in this file are configuration options chosen during
// compilation of libcwd.  To change these options, rerun CMake with
// the appropriate -D options. In order to be sure that a program is linking
// with a library that was compiled with the same header file, call
//
//   Debug(main_reached());
//
// at the top of main() in your program.
//

/** @defgroup enable_glibcxx_debug `EnableGlibCxxDebug` (`CWDEBUG_GLIBCXX_DEBUG`)
 * @ingroup configuration-options-and-macros
 *
 * @par Description
 *
 * Compile libcwd itself with -D_GLIBCXX_DEBUG.
 * See "Chapter 17. Debug Mode" on https://gcc.gnu.org/onlinedocs/libstdc++/manual/debug_mode_using.html
 *
 * Note that this flag changes the sizes and behavior of standard class templates such
 * as std::vector, and therefore you can only link code compiled with debug mode and
 * code compiled without debug mode if no instantiation of a container is passed
 * between the two translation units. Because this is always the case between your
 * custom debug.cc and libcwd, and most likely in many other cases-- libcwd enforces
 * that every compilation unit that includes libcwd/debug.h uses the same mode.
 *
 * @par When to use it
 *
 * It is a good idea to use this if you suspect problems related to iterators.
 * The disadvantage is that you need to compile your applications also with
 * -D_GLIBCXX_DEBUG and that this debug mode comes with a speed penality.
 *
 * @par CMake option
 *
 * This is disabled by default.
 * Use \shellcommand cmake -DEnableGlibCxxDebug=ON ... \endshellcommand to enable it.
 */

#define CWDEBUG_GLIBCXX_DEBUG @CW_CONFIG_GLIBCXX_DEBUG@

/** @defgroup enable_location `EnableLibcwdLocation` (`CWDEBUG_LOCATION`)
 * @ingroup configuration-options-and-macros
 *
 * @par Description
 *
 * Adds code that supports *source-file*:*line-number* lookup.
 * This will load debugging symbols at the start of a program allowing
 * one to print source file / line number information.<BR><BR>
 * It provides an interface, allowing applications that link
 * with libcwd to print debugging information using the symbol table.
 *
 * @par When to use it
 *
 * As a developer, especially when you want debug output to include source
 * file and line number information.
 *
 * @par CMake option
 *
 * This is enabled by default.
 * Use \shellcommand cmake -DEnableLibcwdLocation=OFF ... \endshellcommand to disable it.
 *
 * @sa @ref source-file-line-number-information
 */

#define CWDEBUG_LOCATION @CW_CONFIG_LOCATION@

/** @defgroup enable_debug `EnableLibcwdDebug` (`CWDEBUG_DEBUG`)
 * @ingroup configuration-options-and-macros
 *
 * @par Description
 *
 * Turns on internal consistency checks of libcwd.
 * The use of these checks can slow down libcwd and are mainly intended for the maintainer of libcwd.
 *
 * @par When to use it
 *
 * When you think you found a bug in libcwd.
 *
 * @par Configure option
 *
 * This is disabled by default.
 * Use \shellcommand cmake -DEnableLibcwdDebug=ON ... \endshellcommand to enable it.
 */

#define CWDEBUG_DEBUG @CW_CONFIG_DEBUG@

/** @defgroup enable_debug_output `EnableLibcwdDebugOutput` (`CWDEBUG_DEBUGOUTPUT`)
 * @ingroup configuration-options-and-macros
 *
 * @par Description
 *
 * When @ref enable_debug is enabled, this turns on a lot of extra debugging
 * output concerning the internal state of libcwd.
 * This will not be usefull to you unless you manage to let the program
 * coredump even before it reaches main().
 *
 * @par When to use it
 *
 * Never, unless you are a developer of libcwd.
 *
 * @par CMake option
 *
 * This is disabled by default.
 * Use \shellcommand cmake -DEnableLibcwdDebug=ON -DEnableLibcwdDebugOutput=ON ... \endshellcommand to enable it.
 */

#define CWDEBUG_DEBUGOUTPUT (CWDEBUG_DEBUG && @CW_CONFIG_DEBUGOUTPUT@)

//
// Configuration defines that are needed by public headers.
//

#define LIBCWD_DO_MAX 8 // Maximal total number of debug objects in a single application.
#define LIBCWD_DC_MAX \
  256 // Maximal total number of debug channels in a single application.
      // Costs 4 kb of memory per channel (exclusive the actual channels).

/** @defgroup enable_debugt `EnableLibcwdDebugt` (`CWDEBUG_DEBUGT`)
 * @ingroup configuration-options-and-macros
 *
 * @par Description
 *
 * Turns on extra diagnostics related to libcwds threading critical areas.
 * The checks are intended for developers who are changing internal locking or thread-lifetime code.
 *
 * @par When to use it
 *
 * Never, unless you are a developer of libcwd.
 * If someone requests it then I might extend this to a user interface however.
 *
 * @par CMake option
 *
 * This is disabled by default.
 * Use \shellcommand cmake -DEnableLibcwdDebug=ON -DEnableLibcwdDebugt=ON ... \endshellcommand to enable it.
 */

#define CWDEBUG_DEBUGT @CW_CONFIG_DEBUGT@

//
// Configuration signature
//

#ifdef __cplusplus
namespace libcwd {

#if CWDEBUG_LOCATION
/**
 * @brief Offset to __builtin_return_address() needed to get the correct line number from Location for the call site.
 *
 * @par Example
 * ```cpp
 * libcwd::Location loc((char*)__builtin_return_address(0) + libcwd::builtin_return_address_offset);
 * ```
 */
inline constexpr int builtin_return_address_offset = @CW_CONFIG_BUILTIN_RETURN_ADDRESS_OFFSET@;
#endif

inline constexpr unsigned long config_signature_header_c = (
#if CWDEBUG_LOCATION
    4 |
#endif
#if CWDEBUG_DEBUG
    16 |
#endif
#if CWDEBUG_DEBUGT
    64 |
#endif
#if CWDEBUG_DEBUGOUTPUT
    256 |
#endif
    (512 * (@VERSION_MAJOR@ + 128 * (@VERSION_MINOR@ + 128 * @VERSION_REVISION@))));

extern unsigned long get_config_signature_lib_c() __attribute__((const));
extern void conf_check_failed();
extern void version_check_failed();
extern void internal_main_reached();

/**
 * @ingroup special-functions-and-utilities
 *
 * @brief Check if the linked library belongs to the header files being used.
 *
 * In order to be sure that the libcwd header files that are being used
 * belong to the \filename libcwd.so \endfilename shared object that the application linked with,
 * add the following line to the beginning of `main()`:
 *
 * ```cpp
 * Debug(main_reached());
 * ```
 */
inline void main_reached()
{
  if (get_config_signature_lib_c() != config_signature_header_c)
  {
    if (get_config_signature_lib_c() / 512 != config_signature_header_c / 512)
      version_check_failed();
    else
      conf_check_failed();
  }
  internal_main_reached();
}

} // namespace libcwd
#endif // __cplusplus

#endif // LIBCWD_CONFIG_H
