# Doxygen configuration for the unified libcwd documentation site.
#
# This file intentionally contains only project-local overrides. It relies on Doxygen defaults for the generated
# template noise and follows the same small Doxylocal-style pattern used by other Doxygen Awesome projects.

DOXYFILE_ENCODING      = UTF-8
PROJECT_NAME           = @PACKAGE_NAME@
PROJECT_NUMBER         = @PACKAGE_VERSION@
PROJECT_BRIEF          = "The C++ Debugging Support Library"
OUTPUT_DIRECTORY       = .

ALIASES                = "exampleoutput=\htmlonly<DIV class=example-output>\endhtmlonly" \
                         endexampleoutput=\htmlonly</DIV>\endhtmlonly \
                         "shellcommand=\htmlonly<SPAN class=shell-command>\endhtmlonly" \
                         endshellcommand=\htmlonly</SPAN>\endhtmlonly

MARKDOWN_SUPPORT       = YES
TOC_INCLUDE_HEADINGS   = 5
USE_MDFILE_AS_MAINPAGE = Introduction.md

INPUT                  = Introduction.md \
                          @srcdir@/release-notes.md \
                          @srcdir@/reference-manual.md \
                          @srcdir@/reference-manual-getting-started.md \
                          @srcdir@/reference-manual-writing-debug-output.md \
                          @srcdir@/reference-manual-symbols.md \
                          @srcdir@/reference-manual-runtime.md \
                          @srcdir@/reference-groups.md \
                          @srcdir@/downloading.md \
                          @srcdir@/preparation.md \
                          @srcdir@/custom-debug.h.md \
                          @top_builddir@/include/libcwd/config.h \
                          @srcdir@/environment.md \
                          @srcdir@/writing_intro.md \
                          @srcdir@/why_macro.md \
                          @srcdir@/destination.md \
                          @srcdir@/debug_object.md \
                          @srcdir@/custom_do.md \
                          @srcdir@/debug_channels.md \
                          @top_srcdir@/src/debug.cxx \
                          @srcdir@/control_flags.md \
                          @srcdir@/formatting.md \
                          @srcdir@/fatal_output.md \
                          @srcdir@/nested.md \
                          @srcdir@/special.md \
                          @srcdir@/symbols_intro.md \
                          @srcdir@/locations.md \
                          @srcdir@/type_info.md \
                          @top_srcdir@/src/demangle.cxx \
                          @srcdir@/function.md \
                          @srcdir@/rcfile.md \
                          @srcdir@/attach_gdb.md \
                          @srcdir@/core_dump.md \
                          @srcdir@/gdb.md \
                          @srcdir@/namespaces.md \
                          @top_srcdir@/include/libcwd \
                          @top_builddir@/include/libcwd
FILE_PATTERNS          = *.md \
                          *.h \
                         *.inl \
                         *.cxx
RECURSIVE              = NO
EXCLUDE_PATTERNS       = timestamp-*.h

EXAMPLE_PATH           = external \
                         @srcdir@/doxygen-examples \
                         @top_srcdir@
EXAMPLE_RECURSIVE      = NO

FULL_PATH_NAMES        = YES
STRIP_FROM_PATH        = @top_srcdir@/include/ \
                         @top_srcdir@/

EXTRACT_ALL            = NO
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_CLASSES  = YES
HIDE_UNDOC_MEMBERS     = YES
HIDE_UNDOC_CLASSES     = YES
ALPHABETICAL_INDEX     = NO
SORT_GROUP_NAMES       = NO
SHOW_NAMESPACES        = YES
SHOW_FILES             = YES
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES

ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = NO
SEARCH_INCLUDES        = YES
INCLUDE_PATH           = ../include
INCLUDE_FILE_PATTERNS  = *.h
PREDEFINED             = CWDEBUG \
                         _REENTRANT \
                         LIBCWD_DOXYGEN \
                         HIDE_FROM_DOXYGEN

GENERATE_HTML          = YES
HTML_OUTPUT            = .
HTML_FILE_EXTENSION    = .html
HTML_HEADER            = @srcdir@/html.header
HTML_FOOTER            = @srcdir@/html.footer
LAYOUT_FILE            = doxygen.layout.xml
HTML_EXTRA_FILES       = @srcdir@/images/doxygen.svg \
                         @srcdir@/doxygen-awesome-css/doxygen-awesome-darkmode-toggle.js
HTML_EXTRA_STYLESHEET  = @srcdir@/doxygen-awesome-css/doxygen-awesome.css \
                         @srcdir@/doxygen-awesome-css/doxygen-awesome-sidebar-only.css \
                         @srcdir@/doxygen-awesome-css/doxygen-awesome-sidebar-only-darkmode-toggle.css
HTML_COLORSTYLE        = LIGHT
GENERATE_TREEVIEW      = YES
TREEVIEW_WIDTH         = 335
DISABLE_INDEX          = NO
FULL_SIDEBAR           = NO
SEARCHENGINE           = YES
SERVER_BASED_SEARCH    = NO

GENERATE_LATEX         = NO
GENERATE_XML           = NO
GENERATE_MAN           = NO
GENERATE_RTF           = NO

QUIET                  = YES
WARNINGS               = YES
WARN_IF_DOC_ERROR      = YES
WARN_AS_ERROR          = NO
WARN_LINE_FORMAT       = "at line $line of file $file"
