# Doxygen configuration for the Markdown-authored front pages.
#
# This is a small, separate Doxygen run so overview.md and release-notes.md
# remain normal Markdown sources while the existing reference manual continues
# to be generated under reference-manual/ by doxygen.config.in.

DOXYFILE_ENCODING      = UTF-8
PROJECT_NAME           = @PACKAGE_NAME@
PROJECT_NUMBER         = @PACKAGE_VERSION@
PROJECT_BRIEF          = "The C++ Debugging Support Library"
OUTPUT_DIRECTORY       = .

MARKDOWN_SUPPORT       = YES
TOC_INCLUDE_HEADINGS   = 0
INPUT                  = about-libcwd.md \
                         release-notes.md
FILE_PATTERNS          = *.md
USE_MDFILE_AS_MAINPAGE = about-libcwd.md

GENERATE_HTML          = YES
HTML_OUTPUT            = .
HTML_FILE_EXTENSION    = .html
HTML_HEADER            = frontpage.header
HTML_FOOTER            = frontpage.footer
LAYOUT_FILE            = frontpage.layout.xml
HTML_COLORSTYLE        = LIGHT # required with Doxygen >= 1.9.5
SEARCHENGINE           = YES
SERVER_BASED_SEARCH    = NO
TREEVIEW_WIDTH         = 335
GENERATE_TREEVIEW      = YES
DISABLE_INDEX          = NO
FULL_SIDEBAR           = NO
HTML_EXTRA_FILES       = @srcdir@/images/doxygen.svg \
                         @srcdir@/doxygen-awesome-css/doxygen-awesome-darkmode-toggle.js
HTML_EXTRA_STYLESHEET  = @srcdir@/doxygen-awesome-css/doxygen-awesome.css \
                         @srcdir@/doxygen-awesome-css/doxygen-awesome-sidebar-only.css \
                         @srcdir@/doxygen-awesome-css/doxygen-awesome-sidebar-only-darkmode-toggle.css
SHOW_FILES             = NO

GENERATE_LATEX         = NO
GENERATE_XML           = NO
GENERATE_MAN           = NO
GENERATE_RTF           = NO

QUIET                  = YES
WARNINGS               = YES
WARN_IF_DOC_ERROR      = YES
WARN_AS_ERROR          = NO
