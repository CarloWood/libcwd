# Doxygen configuration for the Markdown-authored front pages.
#
# This is a small, separate Doxygen run so overview.md and release-notes.md
# remain normal Markdown sources while the existing reference manual continues
# to be generated under reference-manual/ by doxygen.config.in.

DOXYFILE_ENCODING      = UTF-8
PROJECT_NAME           = @PACKAGE_NAME@
PROJECT_NUMBER         = @PACKAGE_VERSION@
PROJECT_BRIEF          = "The C++ Debugging Support Library"
OUTPUT_DIRECTORY       = @top_builddir@/doc

MARKDOWN_SUPPORT       = YES
TOC_INCLUDE_HEADINGS   = 4
INPUT                  = @top_builddir@/doc/about-libcwd.md \
                         @srcdir@/release-notes.md
FILE_PATTERNS          = *.md
USE_MDFILE_AS_MAINPAGE = @top_builddir@/doc/about-libcwd.md

GENERATE_HTML          = YES
HTML_OUTPUT            = .
HTML_FILE_EXTENSION    = .html
HTML_HEADER            = @top_builddir@/doc/frontpage.header
HTML_FOOTER            = @top_builddir@/doc/frontpage.footer
HTML_COLORSTYLE        = LIGHT
SEARCHENGINE           = NO
GENERATE_TREEVIEW      = NO
DISABLE_INDEX          = YES

GENERATE_LATEX         = NO
GENERATE_XML           = NO
GENERATE_MAN           = NO
GENERATE_RTF           = NO

QUIET                  = YES
WARNINGS               = YES
WARN_IF_DOC_ERROR      = YES
WARN_AS_ERROR          = NO
