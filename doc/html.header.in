<!doctype html>
<html lang="en-us">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="author" content="Carlo Wood">
  <meta name="description" content="libcwd is a C++ debugging support library with ostream debug output, debug channels, source locations, and demangled type names.">
  <title>$projectname: $title</title>
  <link href="$relpath^tabs.css" rel="stylesheet" type="text/css">
  <script type="text/javascript" src="$relpath^jquery.js"></script>
  <script type="text/javascript" src="$relpath^dynsections.js"></script>
  <script type="text/javascript" src="$relpath^../doxygen-awesome-css/doxygen-awesome-fragment-copy-button.js"></script>
  <script type="text/javascript" src="$relpath^../doxygen-awesome-css/doxygen-awesome-paragraph-link.js"></script>
  <script type="text/javascript" src="$relpath^../doxygen-awesome-css/doxygen-awesome-interactive-toc.js"></script>
  $treeview
  $search
  <link href="$relpath^$stylesheet" rel="stylesheet" type="text/css">
  <link rel="stylesheet" href="$relpath^../doxygen-awesome-css/doxygen-awesome.css">
  <link rel="stylesheet" href="$relpath^../doxygen-awesome-css/doxygen-awesome-sidebar-only.css">
  <link rel="stylesheet" href="$relpath^../doxygen-awesome-css/doxygen-awesome-sidebar-only-darkmode-toggle.css">
  <link rel="stylesheet" href="$relpath^../css/libcwd-front-page.css">
  <script type="text/javascript" src="$relpath^../doxygen-awesome-css/doxygen-awesome-darkmode-toggle.js"></script>
  <script type="text/javascript" src="$relpath^../scripts/libcwd-doxygen-theme.js"></script>
  <script type="text/javascript">
    DoxygenAwesomeFragmentCopyButton.init();
    DoxygenAwesomeParagraphLink.init();
    DoxygenAwesomeInteractiveToc.init();
    DoxygenAwesomeDarkModeToggle.lightModeIcon = '🌞';
    DoxygenAwesomeDarkModeToggle.darkModeIcon = '🌘';
    DoxygenAwesomeDarkModeToggle.init();
  </script>
</head>
<body>
<div id="top"><!-- do not remove this div, it is closed by doxygen! -->
<div id="titlearea">
  <div id="projectalign">
    <div id="projectname"><a class="brand__name" href="$relpath^../index.html"><span class="brand__letters">libcw</span><span class="brand__mark">d</span></a><span id="projectnumber">version $projectnumber</span></div>
    <div id="projectbrief">The C++ Debugging Support Library</div>
  </div>
</div>
